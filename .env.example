# Biubo WAF - Docker Compose Environment Configuration
# Copy this file to .env and customize values for your deployment

# ===== Project =====
DOCKER_COMPOSE_PROJECT_NAME=biubo-waf

# ===== WAF Core =====
WAF_PORT=80
WAF_DASHBOARD_PASSWORD=changeme_secure_password
WAF_CORS_ORIGINS=["http://localhost:3000"]
WAF_PROXY_MAP={}
WAF_DASHBOARD_PATH=/biubo-cgi

# ===== LLM / AI Detection =====
WAF_API_KEY=your_dashscope_api_key
WAF_LLM_MODEL=qwen-plus
WAF_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== Storage Configuration =====
# Options: msgpack, redis, postgres
STORAGE_DRIVER=msgpack
STORAGE_REDIS_URL=redis://redis:6379
STORAGE_POSTGRES_URL=postgresql://biubo:biubo@postgres:5432/biubo

# ===== SSL / HTTPS =====
SSL_ENABLED=false
SSL_DOMAINS=
SSL_ACME_EMAIL=
SSL_CERT_DIR=/app/ssl
SSL_PORT=443

# ===== Session & Cache =====
WAF_SESSION_TIMEOUT=20
WAF_CACHE_TTL=3600
WAF_SESSION_GC_INTERVAL=5
WAF_CACHE_GC_INTERVAL=30

# ===== Rate Limiting =====
WAF_RATE_LIMIT=15
WAF_BAN_THRESHOLD=30
WAF_BAN_DURATION=60
WAF_RATE_GC_INTERVAL=10

# ===== Challenge / Captcha =====
WAF_CHALLENGE_SECRET=
WAF_CHALLENGE_EXPIRE=3600

# ===== Upload =====
WAF_MAX_UPLOAD_SIZE=10485760

# ===== Logging =====
WAF_LOG_AUTO_DELETE=false
WAF_LOG_RETENTION_DAYS=30
WAF_LOG_RETAIN_LIST=type:hacker

# ===== IP Detection =====
WAF_TRUST_HEADERS=true
WAF_IP_HEADER_ORDER=["CF-Connecting-IP","X-Real-IP","X-Forwarded-For"]

# ===== Ports =====
WAF_HTTP_PORT=80
WAF_HTTPS_PORT=443
REDIS_PORT=6379
POSTGRES_PORT=5432

# ===== PostgreSQL =====
POSTGRES_USER=biubo
POSTGRES_PASSWORD=biubo
POSTGRES_DB=biubo

# ===== Logging Level =====
RUST_LOG=info
