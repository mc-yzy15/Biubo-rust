#!/bin/bash

set -e

if [ "$1" = "purge" ]; then
    echo "Purging biubo-waf data..."
    
    if id "biubo" &>/dev/null; then
        userdel biubo 2>/dev/null || true
    fi
    
    rm -rf /etc/biubo-waf
    rm -rf /var/lib/biubo-waf
    rm -rf /var/log/biubo-waf
    
    echo "Purge complete."
fi
